# =============================================================================
# Darija-ASR · .gitignore
# =============================================================================
# Adapters, training checkpoints, and HF caches do NOT go in git.
# They live on HuggingFace Hub (adapters) or are re-downloaded (datasets).
# Only code, methodology docs, and small result CSVs/JSONs/PNGs are tracked.

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.python-version
.venv/
venv/
env/
ENV/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# --- Model artifacts (large; live on HF Hub) ---
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
adapter_model.*
pytorch_model.bin
model.safetensors

# Trainer + best-checkpoint output directories (regenerable)
/workspace/
outputs/
trainer_*/
best_marco_asr_*/
final_*/
checkpoint-*/

# HF caches (regenerable)
.cache/
.huggingface/

# Per-utterance details files can be large — keep summaries, drop details by default.
# Uncomment if you want to commit them:
# !results/*_details.json

# --- Secrets ---
.env
.env.local
*.token
hf_token*
api_keys*

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Build / packaging ---
build/
dist/
*.tar.gz
*.zip

# --- Logs (regenerable; small ones are fine to keep) ---
*.log
logs/marco_history_*.json  # comment this line out if you want to commit history JSONs

# --- Local-only configuration ---
config.local.py
config.local.json
